# vLLM server configuration (sourced by 20_run_vllm_cosmos.sh).
# Tuned for Orin Nano 8 GB on JetPack 6.2.2+ (L4T 36.5.0+).
# Proven-working values.

# Model — HuggingFace model ID, vLLM downloads on first run.
# Using Embedl's W4A16 quantization because the raw BF16 model from
# NVIDIA exceeds Orin Nano 8GB memory during multimodal profiling.
# Alternative: NVIDIA's FP8 checkpoint from NGC
# (nim/nvidia/cosmos-reason2-2b:1208-fp8-static-kv8) — requires NGC CLI.
MODEL_ID=embedl/Cosmos-Reason2-2B-W4A16

# Context window. 256 is the Orin Nano 8GB ceiling with this serve config
# and model. Trying higher triggers vLLM's KV-cache sanity check:
#   ValueError: No available memory for the cache blocks
# At max_model_len=2048, activations consume 3+ GB during warmup.
MAX_MODEL_LEN=256
MAX_NUM_BATCHED_TOKENS=256

# Fraction of free GPU memory vLLM may use. 0.6 is what actually passes
# startup on this hardware. 0.65-0.7 fails the "free memory < desired"
# sanity check because free memory fluctuates around 5.1-5.2 GB.
GPU_MEM_UTIL=0.6

# Multimodal caps — prevent the ViT encoder from consuming the entire
# context budget. 150528 = ~388x388 max input image resolution.
MAX_PIXELS=150528
NUM_FRAMES=2

# Single-request serving. Concurrency requires more KV cache headroom
# than we have.
MAX_NUM_SEQS=1

# Network
HOST=0.0.0.0
PORT=8000

# Container image. Same for Jetson AGX Orin and Orin Super Nano per
# NVIDIA's documentation.
IMAGE=ghcr.io/nvidia-ai-iot/vllm:latest-jetson-orin

# HuggingFace cache (shared across container runs to avoid re-downloads)
HF_CACHE=$HOME/.cache/huggingface
