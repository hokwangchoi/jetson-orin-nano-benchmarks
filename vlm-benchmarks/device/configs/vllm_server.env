# vLLM server configuration for Cosmos-Reason2-2B-W4A16 on Jetson Orin Nano.
# Reproduces Embedl's reference setup, with two Orin-Nano-specific adjustments.
# https://huggingface.co/embedl/Cosmos-Reason2-2B-W4A16

# Model — HuggingFace ID or absolute local path (auto-detected by the script)
MODEL=embedl/Cosmos-Reason2-2B-W4A16

# Container image
VLLM_IMAGE=ghcr.io/nvidia-ai-iot/vllm:latest-jetson-orin

# Server bind
HOST=0.0.0.0
PORT=8000

# These four flags match Embedl's published command.
MAX_MODEL_LEN=1024
GPU_MEM_UTIL=0.65
MAX_NUM_SEQS=1

# Two Orin-Nano-specific additions not in Embedl's card.
# Without these, vLLM's profile_run tries to allocate ~1 GB contiguous memory
# for the vision encoder at Qwen3-VL's default max image size (~1.4M pixels).
# That allocation fails on Tegra NvMap and cascades into the L4T 36.4.7
# PyTorch allocator bug (NVML_SUCCESS assert in CUDACachingAllocator.cpp:1154).
# Capping max_pixels and declaring MM limits keeps the profile run within budget.
MM_PROCESSOR_KWARGS='{"num_frames":2,"max_pixels":150528}'
LIMIT_MM_PER_PROMPT='{"image":1,"video":1}'
