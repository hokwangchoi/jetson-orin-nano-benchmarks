# vLLM server configuration (sourced by 03_run_vllm_server.sh).
# Tuned for Orin Nano 8 GB. Override any of these in your shell env.
#
# MODEL_PATH may be either a Hugging Face model ID (default) or a local
# directory. The launch script detects which and configures Docker
# accordingly.

# Default: pull Embedl's pre-quantized W4A16 checkpoint from HF.
# When you do your own quantization later (Phase 0), point this at your
# local artifact directory, e.g. $HOME/vlm-artifacts/vllm/Cosmos-Reason2-2B-W4A16
MODEL_PATH=embedl/Cosmos-Reason2-2B-W4A16
SERVED_NAME=Cosmos-Reason2-2B-W4A16
PORT=8000

# 4096 is conservative but safe on 8 GB with headless-but-alive OS.
# Bump to 8192 once you confirm the server starts cleanly; drop to 2048
# if you hit KV cache pressure under concurrent load.
MAX_MODEL_LEN=4096

# 0.6 leaves room for CUDA driver context + PyTorch init overhead.
# With ~4.9 GiB free on the GPU at startup, this reserves 4.46 GiB
# (0.6 * 7.44 total) for vLLM — fits with ~0.4 GiB safety margin.
# Measured free memory: `nvidia-smi --query-gpu=memory.free --format=csv`
# (or for Jetson: check the "free on cuda:0" line in any prior vLLM error).
GPU_MEM_UTIL=0.6

# 2 concurrent requests is the safe ceiling; bump to 4 for concurrency tests
# only after confirming steady-state memory under 1 concurrent request.
MAX_NUM_SEQS=2

IMAGE=ghcr.io/nvidia-ai-iot/vllm:latest-jetson-orin
