# vLLM server configuration (sourced by 03_run_vllm_server.sh).
# Tuned for Orin Nano 8 GB on JetPack 6.2 (L4T 36.4.7).
#
# L4T 36.4.7 includes a security patch (CVE-2025-33182/33177) that caps
# allocable CUDA memory on Jetson. Values below are set to survive that
# cap; once we confirm the runtime starts we can push them up.
#
# MODEL_PATH may be either a Hugging Face model ID (default) or a local
# directory. The launch script detects which and configures Docker
# accordingly.

MODEL_PATH=embedl/Cosmos-Reason2-2B-W4A16
SERVED_NAME=Cosmos-Reason2-2B-W4A16
PORT=8000

# 2048 keeps KV cache small during initial smoketest. Bump after it
# starts cleanly.
MAX_MODEL_LEN=2048

# 0.6 * 7.44 GiB = 4.46 GiB, fits in ~4.9 GiB of CUDA-visible free
# memory after driver overhead.
GPU_MEM_UTIL=0.6

# Single sequence only for the smoketest — no concurrency until basic
# server startup is confirmed.
MAX_NUM_SEQS=1

# Text-only mode: skip vision encoder profile (which is what the
# L4T 36.4.7 memory cap crashes on). Flip to 1 once text serving works.
LIMIT_MM_IMAGE=0
LIMIT_MM_VIDEO=0

IMAGE=ghcr.io/nvidia-ai-iot/vllm:latest-jetson-orin
