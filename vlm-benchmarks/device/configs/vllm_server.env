# vLLM server configuration for Cosmos-Reason2-2B-W4A16 on Jetson Orin Nano.
# Reproduces Embedl's reference setup exactly.
# https://huggingface.co/embedl/Cosmos-Reason2-2B-W4A16

# Model — HuggingFace ID or absolute local path (auto-detected by the script)
MODEL=embedl/Cosmos-Reason2-2B-W4A16

# Container image
VLLM_IMAGE=ghcr.io/nvidia-ai-iot/vllm:latest-jetson-orin

# Server bind
HOST=0.0.0.0
PORT=8000

# vLLM flags — these four match Embedl's published command exactly.
# Do not add --enforce-eager, --quantization, --enable-chunked-prefill,
# --compilation-config, --trust-remote-code, or --limit-mm-per-prompt
# unless you want to diverge from the reference.
MAX_MODEL_LEN=8192
GPU_MEM_UTIL=0.75
MAX_NUM_SEQS=2
