# vLLM server configuration (sourced by 03_run_vllm_server.sh).
# Tuned for Orin Nano 8 GB. Override any of these in your shell env to sweep.

MODEL_PATH=embedl/Cosmos-Reason2-2B-W4A16
SERVED_NAME=Cosmos-Reason2-2B-W4A16
PORT=8000

# 8192 is Embedl's published setting; drop to 4096 if KV pressure OOMs.
MAX_MODEL_LEN=8192

# 0.75 leaves ~2 GB of 8 GB for OS + vision encoder scratch + activations.
GPU_MEM_UTIL=0.75

# 2 concurrent requests is the safe ceiling; bump to 4 for concurrency tests.
MAX_NUM_SEQS=2

IMAGE=ghcr.io/nvidia-ai-iot/vllm:latest-jetson-orin
