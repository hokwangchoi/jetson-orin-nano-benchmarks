# llama.cpp server configuration (sourced by 11_run_llamacpp_server.sh).
# Tuned for Orin Nano 8 GB on JetPack 6.2 (L4T 36.4.7).

# Host path where 10_prepare_llamacpp.sh deposited artifacts
MODEL_DIR=$HOME/models/cosmos-reason2-2b
MODEL_FILE=Cosmos-Reason2-2B-Q4_K_M.gguf
MMPROJ_FILE=mmproj-Cosmos-Reason2-2B-BF16.gguf

# Name clients use in API requests; arbitrary, match what the harness sends
SERVED_NAME=Cosmos-Reason2-2B-Q4_K_M

# Network
HOST=0.0.0.0
PORT=8000

# Context window; keep modest for the smoketest, bump after it runs
CTX_SIZE=4096

# -ngl 99 = offload all layers to GPU (model is small enough to fit)
N_GPU_LAYERS=99

# Parallel request slots. llama-server handles concurrency via slot pool.
N_PARALLEL=1

# Container image (same as prepare script)
IMAGE=ghcr.io/nvidia-ai-iot/llama_cpp:latest-jetson-orin
